summary_installation() {
  local C="\033[36m"
  local G="\033[32m"
  local R="\033[31m"
  local B="\033[1m"
  local N="\033[0m"

  local SERVER_IP
  SERVER_IP=$(hostname -I | awk '{print $1}')

  echo ""
  echo -e "${B}╔═══════════════════════════════════════════════════════╗${N}"
  echo -e "${B}║       FSS (F10 Simple Stack) - INSTALLED             ║${N}"
  echo -e "${B}╚═══════════════════════════════════════════════════════╝${N}"
  echo ""
  echo -e "  ${C}Server${N}     : $SERVER_IP"
  echo -e "  ${C}OS${N}         : Ubuntu $OS_VERSION ($CODENAME)"
  echo -e "  ${C}Date${N}       : $(date '+%Y-%m-%d %H:%M:%S')"
  echo -e "  ${C}Log${N}        : $LOGFILE"
  echo ""
  echo -e "${B}─── Services ───────────────────────────────────────────${N}"

  if command -v nginx >/dev/null 2>&1; then
    echo -e "  ${G}✓${N} NGINX        : $(nginx -v 2>&1 | awk -F/ '{print $2}')"
  fi

  if command -v php${PHP_VERSION} >/dev/null 2>&1; then
    echo -e "  ${G}✓${N} PHP-FPM      : $(php${PHP_VERSION} -r 'echo PHP_VERSION;' 2>/dev/null)"
  fi

  if command -v mariadb >/dev/null 2>&1; then
    echo -e "  ${G}✓${N} MariaDB      : $(mariadb --version 2>/dev/null | grep -oP '\d+\.\d+\.\d+' | head -1)"
  fi

  if command -v redis-server >/dev/null 2>&1; then
    echo -e "  ${G}✓${N} Redis        : $(redis-server --version 2>/dev/null | grep -oP '\d+\.\d+\.\d+' | head -1)"
  fi

  if command -v fail2ban-server >/dev/null 2>&1; then
    echo -e "  ${G}✓${N} Fail2Ban     : $(systemctl is-active fail2ban)"
  fi

  if systemctl is-active --quiet filebrowser 2>/dev/null; then
    echo -e "  ${G}✓${N} Filebrowser  : running"
  fi

  echo ""
  echo -e "${B}─── Access Info ────────────────────────────────────────${N}"

  if [[ -d /usr/share/phpmyadmin ]]; then
    echo -e "  ${C}phpMyAdmin${N}   : http://$SERVER_IP/pma"
    if [[ -f "$FSS_SECRETS/.pma_admin_password" ]]; then
      local pma_pass
      pma_pass=$(cat "$FSS_SECRETS/.pma_admin_password")
      echo -e "    User         : adminfss"
      echo -e "    Password     : $pma_pass"
    fi
  fi

  if [[ -f "$FSS_SECRETS/.filebrowser_admin" ]]; then
    local fb_user fb_pass
    fb_user=$(jq -r '.username' "$FSS_SECRETS/.filebrowser_admin" 2>/dev/null)
    fb_pass=$(jq -r '.password' "$FSS_SECRETS/.filebrowser_admin" 2>/dev/null)
    echo -e "  ${C}Filebrowser${N}  : http://$SERVER_IP/fm"
    echo -e "    User         : $fb_user"
    echo -e "    Password     : $fb_pass"
    if [[ -f "$FSS_SECRETS/.filebrowser_token" ]]; then
      echo -e "    Token        : $FSS_SECRETS/.filebrowser_token"
    fi
  fi

  if [[ -f "$FSS_SECRETS/.mysql_root_password" ]]; then
    echo -e "  ${C}MariaDB root${N} : saved → $FSS_SECRETS/.mysql_root_password"
  fi

  echo ""
  echo -e "${B}─── FSS Paths ──────────────────────────────────────────${N}"
  echo -e "  Binary     : $FSS_BASE/"
  echo -e "  Data/Conf  : $FSS_DATA/"
  echo -e "  Secrets    : $FSS_SECRETS/"
  echo -e "  Logs       : /var/log/fss/"
  echo ""
  echo -e "${B}─── Usage ──────────────────────────────────────────────${N}"
  echo -e "  fss-site add app example.com -php 8.4 -ssl le -app wordpress"
  echo -e "  fss-site add app example.com -php 8.4 -ssl le -app wordpress --mode single"
  echo -e "  fss-site add static example.com -ssl le"
  echo -e "  fss-site add proxy example.com -backends '127.0.0.1:8080' -ssl le"
  echo -e "  fss-site rm app example.com"
  echo -e "  fss-site rm example.com  (auto-detect type)"
  echo ""
  echo -e "${B}═════════════════════════════════════════════════════════${N}"
  echo ""
}

